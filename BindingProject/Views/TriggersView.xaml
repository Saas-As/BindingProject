<UserControl x:Class="BindingProject.Views.TriggersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BindingProject.Views"
             xmlns:loc="clr-namespace:BindingProject.Localization"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="800">

            <!-- Заголовок -->
            <TextBlock Text="{loc:Translate TriggersView_Title}"
                       FontSize="24" FontWeight="Bold" Margin="0,0,0,10"
                       Foreground="#2C3E50"/>

            <TextBlock Text="{loc:Translate TriggersView_Subtitle}"
                       FontSize="14" TextWrapping="Wrap" Margin="0,0,0,20"
                       Foreground="#555"/>

            <!-- ============== 1. PROPERTY TRIGGER ============== -->
            <Border Background="#F0F8FF" Padding="10" Margin="0,5,0,10" CornerRadius="5">
                <TextBlock Text="{loc:Translate TriggersView_PropertyTriggerTitle}" 
                           FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <TextBlock Text="{loc:Translate TriggersView_PropertyTriggerExplanation}" 
                       TextWrapping="Wrap" Margin="0,0,0,10" FontStyle="Italic"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Пример 1: Кнопка с триггером на наведение -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="10">
                    <TextBlock Text="{loc:Translate TriggersView_Example1_Title}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Button Content="{loc:Translate Triggers_Button_HoverMouse}" Height="40" Width="150">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#3498DB"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E67E22"/>
                                        <Setter Property="FontSize" Value="16"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Width" Value="170"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock Text="{loc:Translate TriggersView_Example1_Hint}" 
                               FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Пример 2: CheckBox с триггером на IsChecked -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="10">
                    <TextBlock Text="{loc:Translate TriggersView_Example2_Title}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <CheckBox x:Name="SampleCheckBox"
                              Content="{loc:Translate Triggers_CheckBox_MarkMe}"
                              Margin="5"/>
                    <Border Margin="5,10,5,0" Padding="10" CornerRadius="5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#95A5A6"/>
                                <Setter Property="BorderBrush" Value="#7F8C8D"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=SampleCheckBox}" Value="True">
                                        <Setter Property="Background" Value="#2ECC71"/>
                                        <Setter Property="BorderBrush" Value="#27AE60"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{loc:Translate TriggersView_Example2_Hint}" 
                                   TextWrapping="Wrap" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- Пример 3: Текстбокс с триггером на фокус -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="10">
                    <TextBlock Text="{loc:Translate TriggersView_Example3_Title}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Width="300" HorizontalAlignment="Left">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Padding" Value="8"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="BorderBrush" Value="#BDC3C7"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="#3498DB"/>
                                        <Setter Property="BorderThickness" Value="3"/>
                                        <Setter Property="Background" Value="#EBF5FB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="{loc:Translate TriggersView_Example3_Hint}" 
                               FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ============== 2. DATA TRIGGER ============== -->
            <Border Background="#F0F8FF" Padding="10" Margin="0,20,0,10" CornerRadius="5">
                <TextBlock Text="{loc:Translate TriggersView_DataTriggerTitle}" 
                           FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <TextBlock Text="{loc:Translate TriggersView_DataTriggerExplanation}" 
                       TextWrapping="Wrap" Margin="0,0,0,15" FontStyle="Italic"/>

            <!-- Таблица товаров с DataTriggers -->
            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Border Grid.Row="0" Background="#34495E" Padding="10" CornerRadius="5,5,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{loc:Translate Triggers_Table_Header_Product}"
                                   FontWeight="Bold" Foreground="White"/>
                        <TextBlock Grid.Column="1"
                                   Text="{loc:Translate Triggers_Table_Header_Price}"
                                   FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="2"
                                   Text="{loc:Translate Triggers_Table_Header_Quantity}"
                                   FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="3"
                                   Text="{loc:Translate Triggers_Table_Header_Status}"
                                   FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Стиль для строк таблицы с DataTriggers -->
                <Border Grid.Row="1" Background="White" Padding="10" BorderBrush="#BDC3C7" BorderThickness="1,0,1,1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentProduct.Price}" Value="0">
                                    <Setter Property="Background" Value="#FADBD8"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentProduct.Quantity}" Value="0">
                                    <Setter Property="Background" Value="#FCF3CF"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentProduct.Price}" Value="75000">
                                    <Setter Property="Background" Value="#D4EFDF"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding CurrentProduct.Name}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CurrentProduct.Price, StringFormat={}{0:N0} руб}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding CurrentProduct.Quantity}" 
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>

                        <!-- Статус с триггером внутри -->
                        <Border Grid.Column="3" CornerRadius="15" Padding="5" HorizontalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#BDC3C7"/>
                                    <Setter Property="Padding" Value="8,3"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentProduct.Price}" Value="0">
                                            <Setter Property="Background" Value="#E74C3C"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentProduct.Quantity}" Value="0">
                                            <Setter Property="Background" Value="#F39C12"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentProduct.Price}" Value="75000">
                                            <Setter Property="Background" Value="#27AE60"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentProduct.Quantity, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                            <Setter Property="Background" Value="#27AE60"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Foreground="White">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{loc:Translate TriggersView_Status_Normal}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentProduct.Price}" Value="0">
                                                <Setter Property="Text" Value="{loc:Translate TriggersView_Status_Free}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentProduct.Quantity}" Value="0">
                                                <Setter Property="Text" Value="{loc:Translate TriggersView_Status_NotAvailable}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentProduct.Price}" Value="75000">
                                                <Setter Property="Text" Value="{loc:Translate TriggersView_Status_Premium}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ============== 3. EVENT TRIGGER ============== -->
            <Border Background="#F0F8FF" Padding="10" Margin="0,20,0,10" CornerRadius="5">
                <TextBlock Text="{loc:Translate TriggersView_EventTriggerTitle}" 
                           FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <TextBlock Text="{loc:Translate TriggersView_EventTriggerExplanation}" 
                       TextWrapping="Wrap" Margin="0,0,0,15" FontStyle="Italic"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Пример 1: Кнопка с анимацией при клике -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="10">
                    <TextBlock Text="{loc:Translate TriggersView_EventExample1_Title}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Button Name="AnimatedButton"
                            Content="{loc:Translate Triggers_Button_ClickMe}"
                            Height="40" Width="150">
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation 
                                            Storyboard.TargetProperty="Opacity" 
                                            From="1" To="0.3" Duration="0:0:0.1" 
                                            AutoReverse="True"/>
                                        <DoubleAnimation 
                                            Storyboard.TargetProperty="RenderTransform.ScaleX" 
                                            From="1" To="0.9" Duration="0:0:0.1" 
                                            AutoReverse="True"/>
                                        <DoubleAnimation 
                                            Storyboard.TargetProperty="RenderTransform.ScaleY" 
                                            From="1" To="0.9" Duration="0:0:0.1" 
                                            AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                        <Button.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Button.RenderTransform>
                    </Button>
                    <TextBlock Text="{loc:Translate TriggersView_EventExample1_Hint}" 
                               FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Пример 2: Квадрат с анимацией при наведении -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="10">
                    <TextBlock Text="{loc:Translate TriggersView_EventExample2_Title}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Border Name="AnimatedSquare" Width="100" Height="100" Background="#3498DB" CornerRadius="5">
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Border.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation 
                                            Storyboard.TargetProperty="Background.Color" 
                                            To="#E67E22" Duration="0:0:0.5"/>
                                        <DoubleAnimation 
                                            Storyboard.TargetProperty="Width" 
                                            To="120" Duration="0:0:0.5"/>
                                        <DoubleAnimation 
                                            Storyboard.TargetProperty="Height" 
                                            To="120" Duration="0:0:0.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Border.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation 
                                            Storyboard.TargetProperty="Background.Color" 
                                            To="#3498DB" Duration="0:0:0.5"/>
                                        <DoubleAnimation 
                                            Storyboard.TargetProperty="Width" 
                                            To="100" Duration="0:0:0.5"/>
                                        <DoubleAnimation 
                                            Storyboard.TargetProperty="Height" 
                                            To="100" Duration="0:0:0.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                </StackPanel>

                <!-- Пример 3: Вращающийся текст -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="10">
                    <TextBlock Text="{loc:Translate TriggersView_EventExample3_Title}" FontWeight="SemiBold" Margin="0,10,0,5"/>
                    <Border Background="#F0F0F0" Padding="20" CornerRadius="5">
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Border.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation 
                                            Storyboard.TargetProperty="Opacity" 
                                            From="1" To="0.3" Duration="0:0:2"/>
                                        <DoubleAnimation 
                                            Storyboard.TargetProperty="RenderTransform.Angle" 
                                            From="0" To="360" Duration="0:0:5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <Border.RenderTransform>
                            <RotateTransform CenterX="75" CenterY="15"/>
                        </Border.RenderTransform>
                        <TextBlock Text="{loc:Translate TriggersView_EventExample3_LargeTitle}" 
                                   FontSize="20" FontWeight="Bold" 
                                   HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ============== 4. MULTI TRIGGER ============== -->
            <Border Background="#F0F8FF" Padding="10" Margin="0,20,0,10" CornerRadius="5">
                <TextBlock Text="{loc:Translate TriggersView_MultiTriggerTitle}" 
                           FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <TextBlock Text="{loc:Translate TriggersView_MultiTriggerExplanation}" 
                       TextWrapping="Wrap" Margin="0,0,0,15" FontStyle="Italic"/>

            <Border Background="White" Padding="15" Margin="0,0,0,20" CornerRadius="5" BorderBrush="#BDC3C7" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{loc:Translate Triggers_Discount_ConditionsLabel}"
                               FontWeight="Bold" Margin="0,0,0,10"/>

                    <CheckBox x:Name="IsRegularCustomer"
                              Content="{loc:Translate Triggers_CheckBox_RegularCustomer}"
                              Margin="5"/>
                    <CheckBox x:Name="HasPromoCode"
                              Content="{loc:Translate Triggers_CheckBox_HasPromoCode}"
                              Margin="5"/>
                    <CheckBox x:Name="IsHoliday"
                              Content="{loc:Translate Triggers_CheckBox_IsHoliday}"
                              Margin="5"/>

                    <Border Margin="5,15,5,0" Padding="15" CornerRadius="5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#BDC3C7"/>
                                <Setter Property="BorderBrush" Value="#7F8C8D"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsChecked, ElementName=IsRegularCustomer}" Value="True"/>
                                            <Condition Binding="{Binding IsChecked, ElementName=HasPromoCode}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="#F39C12"/>
                                        <Setter Property="BorderBrush" Value="#E67E22"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsChecked, ElementName=IsRegularCustomer}" Value="True"/>
                                            <Condition Binding="{Binding IsChecked, ElementName=HasPromoCode}" Value="True"/>
                                            <Condition Binding="{Binding IsChecked, ElementName=IsHoliday}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="#27AE60"/>
                                        <Setter Property="BorderBrush" Value="#2ECC71"/>
                                        <Setter Property="BorderThickness" Value="3"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <TextBlock Text="{loc:Translate Triggers_MyDiscountLabel}"
                                       FontWeight="Bold" Foreground="White"/>
                            <TextBlock Foreground="White" FontSize="24" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="0%"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsChecked, ElementName=IsRegularCustomer}" Value="True"/>
                                                    <Condition Binding="{Binding IsChecked, ElementName=HasPromoCode}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Text" Value="10%"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsChecked, ElementName=IsRegularCustomer}" Value="True"/>
                                                    <Condition Binding="{Binding IsChecked, ElementName=HasPromoCode}" Value="True"/>
                                                    <Condition Binding="{Binding IsChecked, ElementName=IsHoliday}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Text" Value="25%"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ИТОГОВАЯ ТАБЛИЦА -->
            <Border Background="#E8F5E9" Padding="20" Margin="0,20,0,0" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="{loc:Translate TriggersView_SummaryTitle}" 
                               FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Translate TriggersView_Summary_PropertyTrigger}" FontWeight="Bold" Foreground="#2980B9"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{loc:Translate TriggersView_Summary_PropertyTriggerDescription}" Margin="10,0"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Translate TriggersView_Summary_DataTrigger}" FontWeight="Bold" Foreground="#27AE60" Margin="0,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{loc:Translate TriggersView_Summary_DataTriggerDescription}" Margin="10,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Translate TriggersView_Summary_EventTrigger}" FontWeight="Bold" Foreground="#E67E22" Margin="0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{loc:Translate TriggersView_Summary_EventTriggerDescription}" Margin="10,5"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Translate TriggersView_Summary_MultiTrigger}" FontWeight="Bold" Foreground="#8E44AD" Margin="0,5"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{loc:Translate TriggersView_Summary_MultiTriggerDescription}" Margin="10,5"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>