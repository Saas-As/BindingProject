<UserControl x:Class="BindingProject.Views.DefaultBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <StackPanel Margin="20" MaxWidth="400">
        <TextBlock Text="🔹 Привязка по умолчанию (Default)"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"
                   Foreground="#2C3E50"/>

        <!-- Название товара -->
        <TextBlock Text="📦 Название товара:" Margin="0,10,0,5" FontSize="14"/>
        <TextBox Text="{Binding CurrentProduct.Name}" 
                 Padding="8" FontSize="14"
                 BorderBrush="#3498DB" BorderThickness="2"/>

        <!-- Цена -->
        <TextBlock Text="💰 Цена (руб):" Margin="0,10,0,5" FontSize="14"/>
        <TextBox Text="{Binding CurrentProduct.Price}" 
                 Padding="8" FontSize="14"
                 BorderBrush="#3498DB" BorderThickness="2"/>

        <!-- Количество -->
        <TextBlock Text="🔢 Количество:" Margin="0,10,0,5" FontSize="14"/>
        <TextBox Text="{Binding CurrentProduct.Quantity}" 
                 Padding="8" FontSize="14"
                 BorderBrush="#3498DB" BorderThickness="2"/>

        <!-- Итого (только для чтения) -->
        <TextBlock Text="🧾 Итого:" Margin="0,15,0,5" FontSize="14" FontWeight="Bold"/>
        <TextBox Text="{Binding CurrentProduct.Total, Mode=OneWay}" 
                 Padding="8" FontSize="16" FontWeight="Bold"
                 Background="#ECF0F1" BorderBrush="#2ECC71" BorderThickness="2"
                 IsReadOnly="True"/>

        <!-- Пояснение -->
        <Border Background="#E8F5E9" Padding="10" Margin="0,20,0,0" CornerRadius="5">
            <StackPanel>
            <TextBlock Text="📌 Что демонстрирует привязка Default:"
                       FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <TextBlock Text="• TextBox обновляет модель при потере фокуса" 
                           Margin="10,2,0,2"/>
            <TextBlock Text="• Total обновляется автоматически при изменении цены или количества" 
                           Margin="10,2,0,2"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>