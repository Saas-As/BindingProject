<UserControl x:Class="BindingProject.Views.DefaultBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20" MaxWidth="450">
        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[DefaultBindingView_Title]}"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"
                   Foreground="#2C3E50"/>

            <!-- ОПИСАНИЕ -->
            <Border Background="#F0F8FF" Padding="12" Margin="0,0,0,20" CornerRadius="5">
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[DefaultBindingView_Description]}" 
               TextWrapping="Wrap"/>
            </Border>

            <!-- РЕДАКТИРУЕМЫЕ ПОЛЯ -->
        <Border Background="#F5F5F5" Padding="15" CornerRadius="5" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[DefaultBindingView_EditableFieldsTitle]}" 
                           FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>

                <!-- Название товара -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Source={StaticResource Loc}, Path=Item[Label_NameColon]}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding CurrentProduct.Name}" 
                             Padding="8"/>
                </Grid>

                <!-- Цена -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Source={StaticResource Loc}, Path=Item[Label_PriceRubColon]}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding CurrentProduct.Price}" 
                             Padding="8"/>
                </Grid>

                <!-- Количество -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Source={StaticResource Loc}, Path=Item[Label_QuantityColon]}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding CurrentProduct.Quantity}" 
                             Padding="8"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ОТОБРАЖЕНИЕ ДАННЫХ (OneWay) -->
        <Border Background="#EBF5FB" Padding="15" CornerRadius="5" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[DefaultBindingView_DisplayDataTitle]}" 
                           FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,10"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Source={StaticResource Loc}, Path=Item[Label_NameColon]}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" 
                               Text="{Binding CurrentProduct.Name}" 
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Source={StaticResource Loc}, Path=Item[Label_PriceColon]}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:N0} {1}">
                                <Binding Path="CurrentProduct.Price"/>
                                <Binding Source="{StaticResource Loc}" Path="Item[Currency_RublesShort]"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Source={StaticResource Loc}, Path=Item[Label_QuantityColon]}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" 
                               Text="{Binding CurrentProduct.Quantity}" 
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- ИТОГО (выделено) -->
                <Border Background="#D4EFDF" Padding="10" Margin="0,10,0,0" CornerRadius="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={StaticResource Loc}, Path=Item[Label_TotalAllCapsColon]}"
                                   FontWeight="Bold" FontSize="16"/>
                        <TextBlock Grid.Column="1"
                                   FontSize="18" FontWeight="Bold" Foreground="#27AE60">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N0} {1}">
                                    <Binding Path="CurrentProduct.Total"/>
                                    <Binding Source="{StaticResource Loc}" Path="Item[Currency_RublesShort]"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ДЕМОНСТРАЦИЯ UPDATE SOURCE TRIGGER -->
        <Border Background="#FFF9E6" Padding="15" CornerRadius="5" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[DefaultBindingView_UpdateSourceTriggerDemoTitle]}" 
                           FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,10"/>

                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[DefaultBindingView_NormalTextBoxLabel]}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding CurrentProduct.Name}" 
                         Padding="8" Margin="0,0,0,10"/>

                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[DefaultBindingView_PropertyChangedTextBoxLabel]}" Margin="0,5,0,5"/>
                <TextBox Text="{Binding CurrentProduct.Name, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="8" Background="#FFF2CC"/>

                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[DefaultBindingView_DifferenceText]}"
                           FontStyle="Italic" FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- КНОПКА СБРОСА -->
        <Button Content="{Binding Source={StaticResource Loc}, Path=Item[Button_DefaultBinding_ResetToDefault]}" 
                Click="ResetToDefault_Click"
                Padding="12" Margin="0,10,0,0" 
                HorizontalAlignment="Center"
                Background="#3498DB" Foreground="White"
                BorderThickness="0" Cursor="Hand"/>

        <!-- ПОЯСНЕНИЕ -->
        <Border Background="#E8F5E9" Padding="15" Margin="0,20,0,0" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[DefaultBindingView_WhatDefaultShowsLabel]}" 
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                <BulletDecorator Margin="0,0,0,3">
                    <BulletDecorator.Bullet>
                        <TextBlock Text="•" FontWeight="Bold" Foreground="#27AE60"/>
                    </BulletDecorator.Bullet>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[DefaultBindingView_Bullet1]}"
                               TextWrapping="Wrap"/>
                </BulletDecorator>
                <BulletDecorator Margin="0,0,0,3">
                    <BulletDecorator.Bullet>
                        <TextBlock Text="•" FontWeight="Bold" Foreground="#27AE60"/>
                    </BulletDecorator.Bullet>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[DefaultBindingView_Bullet2]}"
                               TextWrapping="Wrap"/>
                </BulletDecorator>
                <BulletDecorator Margin="0,0,0,3">
                    <BulletDecorator.Bullet>
                        <TextBlock Text="•" FontWeight="Bold" Foreground="#E67E22"/>
                    </BulletDecorator.Bullet>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[DefaultBindingView_Bullet3]}"
                               TextWrapping="Wrap"/>
                </BulletDecorator>
            </StackPanel>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>