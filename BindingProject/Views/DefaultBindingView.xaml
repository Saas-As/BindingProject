<UserControl x:Class="BindingProject.Views.DefaultBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20" MaxWidth="450">
        <TextBlock Text="🔹 Привязка по умолчанию (Default)"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"
                   Foreground="#2C3E50"/>

        <!-- ОПИСАНИЕ -->
        <Border Background="#F0F8FF" Padding="12" Margin="0,0,0,20" CornerRadius="5">
                <TextBlock TextWrapping="Wrap">
                <Run Text="Default привязка: WPF сам выбирает режим. Для TextBox это TwoWay (при потере фокуса), для TextBlock это OneWay."/>
            </TextBlock>
        </Border>

        <!-- РЕДАКТИРУЕМЫЕ ПОЛЯ -->
        <Border Background="#F5F5F5" Padding="15" CornerRadius="5" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="✏️ Редактируемые поля (TextBox)" 
                           FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>

                <!-- Название товара -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Название:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding CurrentProduct.Name}" 
                             Padding="8"/>
                </Grid>

                <!-- Цена -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Цена (руб):" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding CurrentProduct.Price}" 
                             Padding="8"/>
                </Grid>

                <!-- Количество -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Количество:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding CurrentProduct.Quantity}" 
                             Padding="8"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ОТОБРАЖЕНИЕ ДАННЫХ (OneWay) -->
        <Border Background="#EBF5FB" Padding="15" CornerRadius="5" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="👁️ Отображение данных (TextBlock с OneWay)" 
                           FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,10"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Название:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" 
                               Text="{Binding CurrentProduct.Name}" 
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Цена:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" 
                               Text="{Binding CurrentProduct.Price, StringFormat={}{0:N0} руб}" 
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Количество:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" 
                               Text="{Binding CurrentProduct.Quantity}" 
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- ИТОГО (выделено) -->
                <Border Background="#D4EFDF" Padding="10" Margin="0,10,0,0" CornerRadius="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ИТОГО:" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding CurrentProduct.Total, StringFormat={}{0:N0} руб}" 
                                   FontSize="18" FontWeight="Bold" Foreground="#27AE60"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ДЕМОНСТРАЦИЯ UPDATE SOURCE TRIGGER -->
        <Border Background="#FFF9E6" Padding="15" CornerRadius="5" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="⚡ Демонстрация UpdateSourceTrigger" 
                           FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,10"/>

                <TextBlock Text="Обычный TextBox (обновление при потере фокуса):" Margin="0,0,0,5"/>
                <TextBox Text="{Binding CurrentProduct.Name}" 
                         Padding="8" Margin="0,0,0,10"/>

                <TextBlock Text="TextBox с PropertyChanged (обновление после каждой буквы):" Margin="0,5,0,5"/>
                <TextBox Text="{Binding CurrentProduct.Name, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="8" Background="#FFF2CC"/>

                <TextBlock Text="✏️ Разница: во втором поле изменения видны сразу в блоке отображения выше"
                           FontStyle="Italic" FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- КНОПКА СБРОСА -->
        <Button Content="↺ Сбросить к значениям по умолчанию" 
                Command="{Binding ResetProductCommand}"
                Padding="12" Margin="0,10,0,0" 
                HorizontalAlignment="Center"
                Background="#3498DB" Foreground="White"
                BorderThickness="0" Cursor="Hand"/>

        <!-- ПОЯСНЕНИЕ -->
        <Border Background="#E8F5E9" Padding="15" Margin="0,20,0,0" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="📌 Что демонстрирует привязка Default:" 
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                <BulletDecorator Margin="0,0,0,3">
                    <BulletDecorator.Bullet>
                        <TextBlock Text="•" FontWeight="Bold" Foreground="#27AE60"/>
                    </BulletDecorator.Bullet>
                    <TextBlock Text="При изменении текста в полях и потере фокуса - обновляется блок отображения" 
                               TextWrapping="Wrap"/>
                </BulletDecorator>
                <BulletDecorator Margin="0,0,0,3">
                    <BulletDecorator.Bullet>
                        <TextBlock Text="•" FontWeight="Bold" Foreground="#27AE60"/>
                    </BulletDecorator.Bullet>
                    <TextBlock Text="ИТОГО обновляется автоматически при изменении цены или количества" 
                               TextWrapping="Wrap"/>
                </BulletDecorator>
                <BulletDecorator Margin="0,0,0,3">
                    <BulletDecorator.Bullet>
                        <TextBlock Text="•" FontWeight="Bold" Foreground="#E67E22"/>
                    </BulletDecorator.Bullet>
                    <TextBlock Text="UpdateSourceTrigger=PropertyChanged - обновление после каждого символа" 
                               TextWrapping="Wrap"/>
                </BulletDecorator>
            </StackPanel>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>