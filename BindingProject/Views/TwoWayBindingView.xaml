<UserControl x:Class="BindingProject.Views.TwoWayBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20" MaxWidth="500">
        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_Title]}"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"
                   Foreground="#2C3E50"/>

            <Border Background="#F0F8FF" Padding="10" Margin="0,0,0,15" CornerRadius="5">
                <TextBlock TextWrapping="Wrap">
        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_Description]}"
                   TextWrapping="Wrap"/>
                </TextBlock>
            </Border>

            <!-- ========== ПРИМЕР 1: Два текстбокса к одному свойству ========== -->
        <Border Background="#F0F0F0" Padding="10" Margin="0,5,0,10" CornerRadius="5">
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_Example1_Title]}"
                       FontWeight="Bold" Foreground="#2C3E50"/>
        </Border>

        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_Label_ProductNameEditAnyField]}" Margin="0,5"/>
        <TextBox x:Name="FirstTextBox" 
                 Text="{Binding CurrentProduct.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,0,0,5" Padding="8"/>

        <TextBox Text="{Binding CurrentProduct.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,0,0,15" Padding="8"/>

        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_UpHintText]}" 
                   FontStyle="Italic" Foreground="Gray" Margin="0,0,0,20"/>

        <!-- ========== ПРИМЕР 2: Слайдер + текстбокс ========== -->
        <Border Background="#F0F0F0" Padding="10" Margin="0,5,0,10" CornerRadius="5">
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_Example2_Title]}"
                       FontWeight="Bold" Foreground="#2C3E50"/>
        </Border>

        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_PriceInstruction]}" Margin="0,5"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
            <TextBox Text="{Binding CurrentProduct.Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Width="100" Padding="8" Margin="0,0,10,0"/>
            <Slider Value="{Binding CurrentProduct.Price, Mode=TwoWay}" 
                    Minimum="0" Maximum="100000" Width="300"
                    IsSnapToTickEnabled="True"
                    TickFrequency="1"/>
        </StackPanel>

        <TextBlock Margin="0,5,0,20">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}{0} {1}">
                    <Binding Path="CurrentProduct.Price"/>
                    <Binding Source="{StaticResource Loc}" Path="Item[Currency_RublesLong]"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <!-- ========== ПРИМЕР 3: CheckBox и видимость ========== -->
        <Border Background="#F0F0F0" Padding="10" Margin="0,5,0,10" CornerRadius="5">
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_Example3_Title]}"
                       FontWeight="Bold" Foreground="#2C3E50"/>
        </Border>

        <CheckBox Content="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_ShowExtraInfoLabel]}" 
                  IsChecked="{Binding ShowExtraInfo, Mode=TwoWay}"
                  Margin="0,5,0,10"/>

        <Border Background="#FFF9E6" Padding="10" Margin="0,0,0,15" 
                Visibility="{Binding ShowExtraInfo, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_ExtraInfoText]}" 
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ========== ПРИМЕР 4: Кнопка обновления данных ========== -->
        <Border Background="#F0F0F0" Padding="10" Margin="0,5,0,10" CornerRadius="5">
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_Example4_Title]}"
                       FontWeight="Bold" Foreground="#2C3E50"/>
        </Border>

        <Button Content="{Binding Source={StaticResource Loc}, Path=Item[Button_SetHighPrice]}" 
                Click="SetHighPrice_Click"
                Padding="15,8" Margin="0,0,10,0" Background="#3498DB" Foreground="White"/>

        <Button Content="{Binding Source={StaticResource Loc}, Path=Item[Button_TwoWay_ResetNameToNewProduct]}" 
                Click="ResetName_Click"
                Padding="15,8" Margin="0,10,10,0" Background="#3498DB" Foreground="White"/>

        <!-- ========== ПОЯСНЕНИЕ ========== -->
        <Border Background="#E8F5E9" Padding="15" Margin="0,20,0,0" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_ExplanationTitle]}" 
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_ExplanationBullet1]}" 
                           Margin="10,2,0,2"/>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_ExplanationBullet2]}" 
                           Margin="10,2,0,2"/>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=Item[TwoWayBindingView_ExplanationBullet3]}" 
                           Margin="10,2,0,2"/>
                </StackPanel>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>