<UserControl x:Class="BindingProject.Views.OneTimeBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:BindingProject.Localization"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="500">

            <!-- Заголовок -->
            <TextBlock Text="{loc:Translate OneTimeBindingView_Title}"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,20"
                       Foreground="#2C3E50"/>

            <!-- ОПИСАНИЕ -->
            <Border Background="#F0F8FF" Padding="15" Margin="0,0,0,20" CornerRadius="5">
                <TextBlock TextWrapping="Wrap">
                    <Run Text="{loc:Translate OneTimeBindingView_DescPart1}" FontWeight="Normal"/>
                    <Run Text="{loc:Translate OneTimeBindingView_DescPart2}" FontWeight="Bold" Foreground="Red"/>
                    <Run Text="{loc:Translate OneTimeBindingView_DescPart3}" FontWeight="Normal"/>
                    <Run Text="{loc:Translate OneTimeBindingView_DescPart4}" FontWeight="Bold" Foreground="Red"/>
                    <Run Text="{loc:Translate OneTimeBindingView_DescPart5}"/>
                </TextBlock>
            </Border>

            <!-- ПРИМЕР 1: Товар с OneTime -->
            <Border Background="#F0F0F0" Padding="10" Margin="0,5,0,10" CornerRadius="5">
                <TextBlock Text="{loc:Translate OneTimeBindingView_Example1_Title}" 
                           FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовки -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Translate OneTimeBindingView_Header_Editor}" 
                           FontWeight="Bold" Foreground="#27AE60" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{loc:Translate OneTimeBindingView_Header_OneTimeFixed}" 
                           FontWeight="Bold" Foreground="#E67E22" Margin="5"/>

                <!-- Название -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{loc:Translate Product_Name}"
                           Margin="5,10,5,2"/>
                <TextBox Grid.Row="2" Grid.Column="0" 
                         Text="{Binding CurrentProduct.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5" Padding="8"/>

                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{loc:Translate Label_NameOneTimeColon}"
                           Margin="5,10,5,2"/>
                <TextBox Grid.Row="2" Grid.Column="1" 
                         Text="{Binding CurrentProduct.Name, Mode=OneTime}" 
                         Margin="5" Padding="8"
                         Background="#FEEFB3" IsReadOnly="True"/>

                <!-- Цена -->
                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="{loc:Translate Product_Price}"
                           Margin="5,10,5,2"/>
                <TextBox Grid.Row="4" Grid.Column="0" 
                         Text="{Binding CurrentProduct.Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5" Padding="8"/>

                <TextBlock Grid.Row="3" Grid.Column="1"
                           Text="{loc:Translate Label_PriceOneTimeColon}"
                           Margin="5,10,5,2"/>
                <TextBox Grid.Row="4" Grid.Column="1" 
                         Text="{Binding CurrentProduct.Price, Mode=OneTime}" 
                         Margin="5" Padding="8"
                         Background="#FEEFB3" IsReadOnly="True"/>

                <!-- Количество -->
                <TextBlock Grid.Row="5" Grid.Column="0"
                           Text="{loc:Translate Product_Quantity}"
                           Margin="5,10,5,2"/>
                <TextBox Grid.Row="6" Grid.Column="0" 
                         Text="{Binding CurrentProduct.Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5" Padding="8"/>

                <TextBlock Grid.Row="5" Grid.Column="1"
                           Text="{loc:Translate Label_QuantityOneTimeColon}"
                           Margin="5,10,5,2"/>
                <TextBox Grid.Row="6" Grid.Column="1" 
                         Text="{Binding CurrentProduct.Quantity, Mode=OneTime}" 
                         Margin="5" Padding="8"
                         Background="#FEEFB3" IsReadOnly="True"/>

                <!-- Итого -->
                <TextBlock Grid.Row="7" Grid.Column="0"
                           Text="{loc:Translate Product_Total}"
                           Margin="5,10,5,2"/>
                <TextBox Grid.Row="8" Grid.Column="0" 
                         Text="{Binding CurrentProduct.Total, Mode=OneWay}" 
                         Margin="5" Padding="8"
                         Background="#E8F5E9" IsReadOnly="True"/>

                <TextBlock Grid.Row="7" Grid.Column="1"
                           Text="{loc:Translate Label_TotalOneTimeColon}"
                           Margin="5,10,5,2"/>
                <TextBox Grid.Row="8" Grid.Column="1" 
                         Text="{Binding CurrentProduct.Total, Mode=OneTime}" 
                         Margin="5" Padding="8"
                         Background="#FEEFB3" IsReadOnly="True"/>
            </Grid>

            <!-- ПРИМЕР 2: Кнопки для изменения данных -->
            <Border Background="#F0F0F0" Padding="10" Margin="0,20,0,10" CornerRadius="5">
                <TextBlock Text="{loc:Translate OneTimeBindingView_Section_ChangeDataInCode}" 
                           FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <WrapPanel Margin="0,0,0,15">
                <Button Content="{loc:Translate Button_OneTime_SetLaptop}" 
                        Click="SetLaptop_Click"
                        Padding="15,8" Margin="0,0,10,5" Background="#3498DB" Foreground="White"/>
                <Button Content="{loc:Translate Button_OneTime_SetPhone}" 
                        Click="SetPhone_Click"
                        Padding="15,8" Margin="0,0,10,5" Background="#3498DB" Foreground="White"/>
                <Button Content="{loc:Translate Button_SetPrice50000}" 
                        Click="SetPrice50000_Click"
                        Padding="15,8" Margin="0,0,10,5" Background="#3498DB" Foreground="White"/>
                <Button Content="{loc:Translate Button_OneTime_ResetAll}" 
                        Click="ResetAll_Click"
                        Padding="15,8" Margin="0,0,0,0" Background="#E74C3C" Foreground="White"/>
            </WrapPanel>

            <!-- ПРИМЕР 3: Слайдер для цены -->
            <Border Background="#F0F0F0" Padding="10" Margin="0,5,0,10" CornerRadius="5">
                <TextBlock Text="{loc:Translate OneTimeBindingView_SliderDemoTitle}" 
                           FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="{loc:Translate OneTimeBindingView_PriceLabel}" VerticalAlignment="Center"/>
                <TextBox Text="{Binding CurrentProduct.Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         Width="100" Padding="5" Margin="5,0"/>
                <Slider Value="{Binding CurrentProduct.Price, Mode=TwoWay}" 
                        IsSnapToTickEnabled="True"
                        TickFrequency="1"
                        Minimum="0" Maximum="100000" Width="250" Margin="10,0"/>
            </StackPanel>

            <!-- НАГЛЯДНАЯ ДЕМОНСТРАЦИЯ -->
            <Border Background="#E8F5E9" Padding="15" Margin="0,20,0,0" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="{loc:Translate OneTimeBindingView_ExplanationTitle}" 
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <BulletDecorator Margin="0,0,0,5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="•" FontWeight="Bold" Foreground="#27AE60"/>
                        </BulletDecorator.Bullet>
                        <TextBlock Text="{loc:Translate OneTimeBindingView_Bullet_LeftColumn}" 
                                   TextWrapping="Wrap"/>
                    </BulletDecorator>

                    <BulletDecorator Margin="0,0,0,5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="•" FontWeight="Bold" Foreground="#E67E22"/>
                        </BulletDecorator.Bullet>
                        <TextBlock Text="{loc:Translate OneTimeBindingView_Bullet_RightColumnFixed}" 
                                   TextWrapping="Wrap"/>
                    </BulletDecorator>

                    <BulletDecorator Margin="0,0,0,5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="•" FontWeight="Bold" Foreground="#E74C3C"/>
                        </BulletDecorator.Bullet>
                        <TextBlock Text="{loc:Translate OneTimeBindingView_Bullet_KeepRightColumnUnchanged}" 
                                   TextWrapping="Wrap" FontWeight="Bold"/>
                    </BulletDecorator>

                    <Line Stroke="LightGray" Margin="0,10" X2="300"/>

                    <TextBlock Text="{loc:Translate OneTimeBindingView_Conclusion}" 
                               TextWrapping="Wrap" FontStyle="Italic" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>