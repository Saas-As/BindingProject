<UserControl x:Class="BindingProject.Views.OneTimeBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="500">
            <TextBlock Text="⏱️ Одноразовая привязка (OneTime)"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"
                   Foreground="#2C3E50"/>

            <!-- ========== ОПИСАНИЕ ========== -->
            <Border Background="#F0F8FF" Padding="15" Margin="0,0,0,20" CornerRadius="5">
                <TextBlock TextWrapping="Wrap">
                <Run Text="OneTime привязка обновляет интерфейс " FontWeight="Normal"/>
                <Run Text="только один раз" FontWeight="Bold" Foreground="Red"/>
                <Run Text="при загрузке. Дальнейшие изменения данных " FontWeight="Normal"/>
                <Run Text="не обновляют" FontWeight="Bold" Foreground="Red"/>
                <Run Text="интерфейс, даже если модель оповещает об изменениях."/>
                </TextBlock>
            </Border>

            <!-- ========== ПРИМЕР 1: Товар с OneTime ========== -->
            <Border Background="#F0F0F0" Padding="10" Margin="0,5,0,10" CornerRadius="5">
                <TextBlock Text="📌 ПРИМЕР 1: OneTime привязка (не обновляется)" 
                       FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовки -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Редактируемые поля (TwoWay)" 
                       FontWeight="Bold" Foreground="#27AE60" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="OneTime привязка (не меняется)" 
                       FontWeight="Bold" Foreground="#E67E22" Margin="5"/>

                <!-- Название -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Название:" Margin="5,10,5,2"/>
                <TextBox Grid.Row="2" Grid.Column="0" 
                     Text="{Binding CurrentProduct.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="5" Padding="8"/>

                <TextBlock Grid.Row="1" Grid.Column="1" Text="Название (OneTime):" Margin="5,10,5,2"/>
                <TextBox Grid.Row="2" Grid.Column="1" 
                     Text="{Binding CurrentProduct.Name, Mode=OneTime}" 
                     Margin="5" Padding="8"
                     Background="#FEEFB3" IsReadOnly="True"/>

                <!-- Цена -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Цена:" Margin="5,10,5,2"/>
                <TextBox Grid.Row="4" Grid.Column="0" 
                     Text="{Binding CurrentProduct.Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="5" Padding="8"/>

                <TextBlock Grid.Row="3" Grid.Column="1" Text="Цена (OneTime):" Margin="5,10,5,2"/>
                <TextBox Grid.Row="4" Grid.Column="1" 
                     Text="{Binding CurrentProduct.Price, Mode=OneTime}" 
                     Margin="5" Padding="8"
                     Background="#FEEFB3" IsReadOnly="True"/>

                <!-- Количество -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Количество:" Margin="5,10,5,2"/>
                <TextBox Grid.Row="6" Grid.Column="0" 
                     Text="{Binding CurrentProduct.Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="5" Padding="8"/>

                <TextBlock Grid.Row="5" Grid.Column="1" Text="Количество (OneTime):" Margin="5,10,5,2"/>
                <TextBox Grid.Row="6" Grid.Column="1" 
                     Text="{Binding CurrentProduct.Quantity, Mode=OneTime}" 
                     Margin="5" Padding="8"
                     Background="#FEEFB3" IsReadOnly="True"/>

                <!-- Итого -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Итого:" Margin="5,10,5,2"/>
                <TextBox Grid.Row="8" Grid.Column="0" 
                     Text="{Binding CurrentProduct.Total, Mode=OneWay}" 
                     Margin="5" Padding="8"
                     Background="#E8F5E9" IsReadOnly="True"/>

                <TextBlock Grid.Row="7" Grid.Column="1" Text="Итого (OneTime):" Margin="5,10,5,2"/>
                <TextBox Grid.Row="8" Grid.Column="1" 
                     Text="{Binding CurrentProduct.Total, Mode=OneTime}" 
                     Margin="5" Padding="8"
                     Background="#FEEFB3" IsReadOnly="True"/>
            </Grid>

            <!-- ========== ПРИМЕР 2: Кнопки для изменения данных ========== -->
            <Border Background="#F0F0F0" Padding="10" Margin="0,20,0,10" CornerRadius="5">
                <TextBlock Text="🔄 Изменяем данные в коде" 
                       FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <WrapPanel Margin="0,0,0,15">
                <Button Content="Установить 'Ноутбук'" 
                    Command="{Binding SetLaptopCommand}"
                    Padding="15,8" Margin="0,0,10,5" Background="#3498DB" Foreground="White"/>
                <Button Content="Установить 'Телефон'" 
                    Command="{Binding SetPhoneCommand}"
                    Padding="15,8" Margin="0,0,10,5" Background="#3498DB" Foreground="White"/>
                <Button Content="Цена 50000" 
                    Command="{Binding SetPriceCommand}"
                    Padding="15,8" Margin="0,0,10,5" Background="#3498DB" Foreground="White"/>
                <Button Content="Сбросить" 
                    Command="{Binding ResetProductCommand}"
                    Padding="15,8" Margin="0,0,0,0" Background="#E74C3C" Foreground="White"/>
            </WrapPanel>

            <!-- ========== ПРИМЕР 3: Слайдер для цены ========== -->
            <Border Background="#F0F0F0" Padding="10" Margin="0,5,0,10" CornerRadius="5">
                <TextBlock Text="🎚️ Слайдер меняет цену (TwoWay)" 
                       FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="Цена: " VerticalAlignment="Center"/>
                <TextBox Text="{Binding CurrentProduct.Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Width="100" Padding="5" Margin="5,0"/>
                <Slider Value="{Binding CurrentProduct.Price, Mode=TwoWay}" 
                    IsSnapToTickEnabled="True"
                    TickFrequency="1"
                    Minimum="0" Maximum="100000" Width="250" Margin="10,0"/>
            </StackPanel>

            <!-- ========== НАГЛЯДНАЯ ДЕМОНСТРАЦИЯ ========== -->
            <Border Background="#E8F5E9" Padding="15" Margin="0,20,0,0" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="📌 Что демонстрирует OneTime привязка:" 
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <BulletDecorator Margin="0,0,0,5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="•" FontWeight="Bold" Foreground="#27AE60"/>
                        </BulletDecorator.Bullet>
                        <TextBlock Text="Левая колонка (TwoWay) - данные обновляются при любых изменениях" 
                               TextWrapping="Wrap"/>
                    </BulletDecorator>

                    <BulletDecorator Margin="0,0,0,5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="•" FontWeight="Bold" Foreground="#E67E22"/>
                        </BulletDecorator.Bullet>
                        <TextBlock Text="Правая колонка (OneTime) - застыла при загрузке и не меняется" 
                               TextWrapping="Wrap"/>
                    </BulletDecorator>

                    <BulletDecorator Margin="0,0,0,5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="•" FontWeight="Bold" Foreground="#E74C3C"/>
                        </BulletDecorator.Bullet>
                        <TextBlock Text="Нажимай кнопки, двигай слайдер - правая колонка остается неизменной" 
                               TextWrapping="Wrap" FontWeight="Bold"/>
                    </BulletDecorator>

                    <Line Stroke="LightGray" Margin="0,10" X2="300"/>

                    <TextBlock Text="📝 Вывод: OneTime привязка берет значение модели один раз при загрузке и больше не обновляется, даже если модель меняется" 
                           TextWrapping="Wrap" FontStyle="Italic" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>