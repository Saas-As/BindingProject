<UserControl x:Class="BindingProject.Views.OneWayBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:BindingProject.Localization"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="550">

            <!-- Заголовок -->
            <TextBlock Text="{loc:Translate OneWayBindingView_Title}"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,20"
                       Foreground="#2C3E50"/>

            <!-- ОПИСАНИЕ -->
            <Border Background="#F0F8FF" Padding="15" Margin="0,0,0,20" CornerRadius="5">
                <TextBlock TextWrapping="Wrap">
                    <Run Text="{loc:Translate OneWayBindingView_DescPart1}" FontWeight="Normal"/>
                    <Run Text="{loc:Translate OneWayBindingView_DescPart2}" FontWeight="Bold" Foreground="Blue"/>
                    <Run Text="{loc:Translate OneWayBindingView_DescPart3}"/>
                </TextBlock>
            </Border>

            <!-- ПРИМЕР 1: Текстблоки только для чтения -->
            <Border Background="#F0F0F0" Padding="10" Margin="0,5,0,10" CornerRadius="5">
                <TextBlock Text="{loc:Translate OneWayBindingView_Example1_Title}" 
                           FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовки -->
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{loc:Translate OneWayBindingView_Header_EditTwoWay}" 
                           FontWeight="Bold" Foreground="#27AE60" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="{loc:Translate OneWayBindingView_Header_ViewOneWay}" 
                           FontWeight="Bold" Foreground="#2980B9" Margin="5"/>

                <!-- Название -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{loc:Translate Product_Name}"
                           Margin="5,10" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" 
                         Text="{Binding CurrentProduct.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5" Padding="8"/>
                <TextBlock Grid.Row="1" Grid.Column="2" 
                           Text="{Binding CurrentProduct.Name, Mode=OneWay}" 
                           Margin="5" Padding="8" VerticalAlignment="Center"
                           Background="#EBF5FB" FontSize="14"/>

                <!-- Цена -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{loc:Translate Product_Price}"
                           Margin="5,10" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" 
                         Text="{Binding CurrentProduct.Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5" Padding="8"/>
                <TextBlock Grid.Row="2" Grid.Column="2"
                           Text="{Binding CurrentProduct.Price, Mode=OneWay, StringFormat={}{0:N0} руб}"
                           Margin="5" Padding="8" VerticalAlignment="Center"
                           Background="#EBF5FB" FontSize="14"/>

                <!-- Количество -->
                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="{loc:Translate Product_Quantity}"
                           Margin="5,10" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" 
                         Text="{Binding CurrentProduct.Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5" Padding="8"/>
                <TextBlock Grid.Row="3" Grid.Column="2" 
                           Text="{Binding CurrentProduct.Quantity, Mode=OneWay}" 
                           Margin="5" Padding="8" VerticalAlignment="Center"
                           Background="#EBF5FB" FontSize="14"/>
            </Grid>

            <!-- ПРИМЕР 2: Прогресс и статус -->
            <Border Background="#F0F0F0" Padding="10" Margin="0,10,0,10" CornerRadius="5">
                <TextBlock Text="{loc:Translate OneWayBindingView_Example2_Title}" 
                           FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Прогресс-бар от цены -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{loc:Translate Label_ProgressPrice}"
                           Margin="5,10" VerticalAlignment="Center"/>
                <ProgressBar Grid.Row="0" Grid.Column="1" 
                             Value="{Binding CurrentProduct.Price, Mode=OneWay}" 
                             Minimum="0" Maximum="100000" Height="25" Margin="5"
                             Foreground="#27AE60"/>

                <!-- Дата последнего обновления -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{loc:Translate Label_LastUpdateTime}"
                           Margin="5,10" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" 
                           Text="{Binding LastUpdateTime, Mode=OneWay, StringFormat='{}{0:HH:mm:ss}'}" 
                           Margin="5" Padding="8" Background="#F0F0F0"/>

                <!-- Итоговая сумма крупно -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{loc:Translate Product_Total}"
                           Margin="5,10" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text="{Binding CurrentProduct.Total, Mode=OneWay, StringFormat={}{0:N0} руб}"
                           FontSize="24" FontWeight="Bold" Foreground="#2ECC71"
                           Margin="5" Padding="8"/>
            </Grid>

            <!-- ПРИМЕР 3: Слайдер управляет ценой -->
            <Border Background="#F0F0F0" Padding="10" Margin="0,10,0,10" CornerRadius="5">
                <TextBlock Text="{loc:Translate OneWayBindingView_Example3_Title}" 
                           FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{loc:Translate OneWayBindingView_ControlSliderLabel}" Margin="0,5"/>
                <Slider Value="{Binding CurrentProduct.Price, Mode=TwoWay}" 
                        Minimum="0" Maximum="100000" TickFrequency="1" 
                        IsSnapToTickEnabled="True" Margin="5"/>

                <WrapPanel Margin="0,10">
                    <TextBlock Text="{loc:Translate OneWayBindingView_CurrentPriceLabel}" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentProduct.Price, Mode=OneWay, StringFormat={}{0:N0} руб}" 
                               FontSize="20" FontWeight="Bold" Foreground="#E67E22"
                               VerticalAlignment="Center" Margin="5,0"/>
                </WrapPanel>

                <WrapPanel>
                    <TextBlock Text="{loc:Translate OneWayBindingView_ProductNameLabel}" FontSize="14"/>
                    <TextBlock Text="{Binding CurrentProduct.Name, Mode=OneWay}" 
                               FontSize="16" FontWeight="SemiBold" Foreground="#2980B9"/>
                </WrapPanel>
            </StackPanel>

            <!-- ПРИМЕР 4: Сравнение OneWay и OneTime -->
            <Border Background="#F0F0F0" Padding="10" Margin="0,10,0,10" CornerRadius="5">
                <TextBlock Text="{loc:Translate OneWayBindingView_Example4_Title}" 
                           FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Заголовки -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Translate OneWayBindingView_CompareGrid_Header_Editor}" 
                           FontWeight="Bold" Foreground="#27AE60" Margin="5" HorizontalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{loc:Translate OneWayBindingView_CompareGrid_Header_OneWay}" 
                           FontWeight="Bold" Foreground="#2980B9" Margin="5" HorizontalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="{loc:Translate OneWayBindingView_CompareGrid_Header_OneTime}" 
                           FontWeight="Bold" Foreground="#E67E22" Margin="5" HorizontalAlignment="Center"/>

                <!-- Данные -->
                <TextBox Grid.Row="1" Grid.Column="0" 
                         Text="{Binding CurrentProduct.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5" Padding="8"/>
                <TextBlock Grid.Row="1" Grid.Column="1" 
                           Text="{Binding CurrentProduct.Name, Mode=OneWay}" 
                           Margin="5" Padding="8" Background="#D4E6F1"/>
                <TextBlock Grid.Row="1" Grid.Column="2" 
                           Text="{Binding CurrentProduct.Name, Mode=OneTime}" 
                           Margin="5" Padding="8" Background="#FAD7A0"/>

                <TextBox Grid.Row="2" Grid.Column="0" 
                         Text="{Binding CurrentProduct.Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5" Padding="8"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text="{Binding CurrentProduct.Price, Mode=OneWay, StringFormat={}{0:N0} руб}" 
                           Margin="5" Padding="8" Background="#D4E6F1"/>
                <TextBlock Grid.Row="2" Grid.Column="2"
                           Text="{Binding CurrentProduct.Price, Mode=OneTime, StringFormat={}{0:N0} руб}" 
                           Margin="5" Padding="8" Background="#FAD7A0"/>
            </Grid>

            <!-- КНОПКИ ДЛЯ ТЕСТИРОВАНИЯ -->
            <Border Background="#F0F0F0" Padding="10" Margin="0,10,0,10" CornerRadius="5">
                <TextBlock Text="{loc:Translate OneWayBindingView_TestButtonsTitle}" 
                           FontWeight="Bold" Foreground="#2C3E50"/>
            </Border>

            <WrapPanel Margin="0,0,0,20">
                <Button Content="{loc:Translate Button_SetLaptop}" 
                        Click="SetLaptop_Click"
                        Padding="15,8" Margin="0,0,10,5" Background="#3498DB" Foreground="White"/>
                <Button Content="{loc:Translate Button_SetPhone}" 
                        Click="SetPhone_Click"
                        Padding="15,8" Margin="0,0,10,5" Background="#3498DB" Foreground="White"/>
                <Button Content="{loc:Translate Button_SetPrice25000}" 
                        Click="SetPrice25000_Click"
                        Padding="15,8" Margin="0,0,10,5" Background="#3498DB" Foreground="White"/>
                <Button Content="{loc:Translate Button_SetPrice75000}" 
                        Click="SetPrice75000_Click"
                        Padding="15,8" Margin="0,0,10,5" Background="#3498DB" Foreground="White"/>
                <Button Content="{loc:Translate Button_Reset}" 
                        Click="Reset_Click"
                        Padding="15,8" Margin="0,0,10,5" Background="#E74C3C" Foreground="White"/>
            </WrapPanel>

            <!-- ИТОГОВОЕ ПОЯСНЕНИЕ -->
            <Border Background="#E8F5E9" Padding="15" Margin="0,10,0,0" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="{loc:Translate OneWayBindingView_ExplanationTitle}" 
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <BulletDecorator Margin="0,0,0,5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="✓" Foreground="#27AE60" FontWeight="Bold"/>
                        </BulletDecorator.Bullet>
                        <TextBlock Text="{loc:Translate OneWayBindingView_Bullet1}" 
                                   TextWrapping="Wrap"/>
                    </BulletDecorator>

                    <BulletDecorator Margin="0,0,0,5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="✓" Foreground="#27AE60" FontWeight="Bold"/>
                        </BulletDecorator.Bullet>
                        <TextBlock Text="{loc:Translate OneWayBindingView_Bullet2}" 
                                   TextWrapping="Wrap"/>
                    </BulletDecorator>

                    <BulletDecorator Margin="0,0,0,5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="✓" Foreground="#27AE60" FontWeight="Bold"/>
                        </BulletDecorator.Bullet>
                        <TextBlock Text="{loc:Translate OneWayBindingView_Bullet3}" 
                                   TextWrapping="Wrap"/>
                    </BulletDecorator>

                    <BulletDecorator Margin="0,0,0,5">
                        <BulletDecorator.Bullet>
                            <TextBlock Text="⚠️" Foreground="#E67E22" FontWeight="Bold"/>
                        </BulletDecorator.Bullet>
                        <TextBlock Text="{loc:Translate OneWayBindingView_Bullet4}" 
                                   TextWrapping="Wrap"/>
                    </BulletDecorator>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>