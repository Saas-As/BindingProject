<Application x:Class="BindingProject.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:BindingProject.Converters"
             xmlns:localization="clr-namespace:BindingProject.Localization"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>

        <localization:LanguageService x:Key="LanguageService"/>
    </Application.Resources>
</Application>