<Application x:Class="BindingProject.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BindingProject"
             xmlns:converters="clr-namespace:BindingProject.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- По умолчанию русский язык -->
                <ResourceDictionary Source="Dictionaries/LangRu.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Конвертеры теперь внутри ResourceDictionary -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>