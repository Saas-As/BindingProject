<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Заголовки вкладок -->
    <system:String x:Key="Tab_DefaultBinding">Привязка по умолчанию</system:String>
    <system:String x:Key="Tab_TwoWayBinding">Двухсторонняя привязка</system:String>
    <system:String x:Key="Tab_OneTimeBinding">Одноразовая привязка</system:String>
    <system:String x:Key="Tab_OneWayBinding">Односторонние привязки</system:String>
    <system:String x:Key="Tab_Triggers">Триггеры</system:String>

    <!-- Заголовок окна -->
    <system:String x:Key="Language_Label">Язык:</system:String>
    <system:String x:Key="MainWindow_Title">Локализация WPF (Dictionary)</system:String>

    <!-- Общие надписи -->
    <system:String x:Key="Product_Name">Название</system:String>
    <system:String x:Key="Product_Price">Цена</system:String>
    <system:String x:Key="Product_Quantity">Количество</system:String>
    <system:String x:Key="Product_Total">Итого</system:String>

    <!-- Кнопки -->
    <system:String x:Key="Button_Reset">Сброс</system:String>
    <system:String x:Key="Button_SetHighPrice">Установить цену 99999</system:String>
    <system:String x:Key="Button_SetLaptop">Ноутбук</system:String>
    <system:String x:Key="Button_SetPhone">Телефон</system:String>
    <system:String x:Key="Button_SetPrice25000">Цена 25000</system:String>
    <system:String x:Key="Button_SetPrice75000">Цена 75000</system:String>

    <!-- Сообщения -->
    <system:String x:Key="Message_PriceChanged">Цена изменена на {0} рублей</system:String>

    <!-- Валюта -->
    <system:String x:Key="Currency_Rubles">руб</system:String>
    <system:String x:Key="Currency_RublesShort">руб</system:String>

    <!-- DefaultBindingView -->
    <system:String x:Key="DefaultBindingView_Title">🔹 Привязка по умолчанию (Default)</system:String>
    <system:String x:Key="DefaultBindingView_Description">Default привязка: WPF сам выбирает режим. Для TextBox это TwoWay (при потере фокуса), для TextBlock это OneWay.</system:String>
    <system:String x:Key="DefaultBindingView_EditableFieldsTitle">✏️ Редактируемые поля (TextBox)</system:String>
    <system:String x:Key="DefaultBindingView_DisplayDataTitle">👁️ Отображение данных (TextBlock)</system:String>
    <system:String x:Key="DefaultBindingView_UpdateSourceTriggerDemoTitle">⚡ Демонстрация UpdateSourceTrigger</system:String>
    <system:String x:Key="DefaultBindingView_NormalTextBoxLabel">Обычный TextBox (обновление при потере фокуса):</system:String>
    <system:String x:Key="DefaultBindingView_PropertyChangedTextBoxLabel">TextBox с PropertyChanged (обновление после каждой буквы):</system:String>
    <system:String x:Key="DefaultBindingView_DifferenceText">✏️ Разница: во втором поле изменения видны сразу в блоке отображения выше</system:String>
    <system:String x:Key="DefaultBindingView_WhatDefaultShowsLabel">📌 Что демонстрирует привязка Default:</system:String>
    <system:String x:Key="DefaultBindingView_Bullet1">При изменении текста в полях и потере фокуса - обновляется блок отображения</system:String>
    <system:String x:Key="DefaultBindingView_Bullet2">ИТОГО обновляется автоматически при изменении цены или количества</system:String>
    <system:String x:Key="DefaultBindingView_Bullet3">UpdateSourceTrigger=PropertyChanged - обновление после каждого символа</system:String>
    <system:String x:Key="Button_DefaultBinding_ResetToDefault">↺ Сбросить к значениям по умолчанию</system:String>

    <!-- TwoWayBindingView -->
    <system:String x:Key="TwoWayBindingView_Title">🔄 Двухсторонняя привязка (TwoWay)</system:String>
    <system:String x:Key="TwoWayBindingView_Description">Двусторонняя привязка: изменения в любом поле обновляют все связанные элементы</system:String>
    <system:String x:Key="TwoWayBindingView_Example1_Title">📌 ПРИМЕР 1: Два текстбокса связаны с одним свойством</system:String>
    <system:String x:Key="TwoWayBindingView_Label_ProductNameEditAnyField">Название товара (редактируй любое поле):</system:String>
    <system:String x:Key="TwoWayBindingView_UpHintText">⬆️ Изменяй текст в любом поле — второй обновляется сразу</system:String>
    <system:String x:Key="TwoWayBindingView_Example2_Title">📌 ПРИМЕР 2: Слайдер и текстбокс для цены</system:String>
    <system:String x:Key="TwoWayBindingView_PriceInstruction">Цена (двигай слайдер или вводи число):</system:String>
    <system:String x:Key="TwoWayBindingView_Example3_Title">📌 ПРИМЕР 3: CheckBox управляет видимостью</system:String>
    <system:String x:Key="TwoWayBindingView_ShowExtraInfoLabel">Показать дополнительную информацию</system:String>
    <system:String x:Key="TwoWayBindingView_ExtraInfoText">Это дополнительная информация, которая появляется/скрывается по чекбоксу</system:String>
    <system:String x:Key="TwoWayBindingView_Example4_Title">📌 ПРИМЕР 4: Изменение данных в коде</system:String>
    <system:String x:Key="TwoWayBindingView_ExplanationTitle">📌 Что демонстрирует TwoWay привязка:</system:String>
    <system:String x:Key="TwoWayBindingView_ExplanationBullet1">• Изменения в интерфейсе → обновляют модель</system:String>
    <system:String x:Key="TwoWayBindingView_ExplanationBullet2">• Изменения в модели (кнопки) → обновляют интерфейс</system:String>
    <system:String x:Key="TwoWayBindingView_ExplanationBullet3">• Все элементы синхронизированы между собой</system:String>
    <system:String x:Key="Button_TwoWay_ResetNameToNewProduct">Сбросить название на "Новый товар"</system:String>

    <!-- OneTimeBindingView -->
    <system:String x:Key="OneTimeBindingView_Title">⏱️ Одноразовая привязка (OneTime)</system:String>
    <system:String x:Key="OneTimeBindingView_DescPart1">OneTime привязка обновляет интерфейс</system:String>
    <system:String x:Key="OneTimeBindingView_DescPart2">только один раз</system:String>
    <system:String x:Key="OneTimeBindingView_DescPart3">при загрузке. Дальнейшие изменения данных</system:String>
    <system:String x:Key="OneTimeBindingView_DescPart4">не обновляют</system:String>
    <system:String x:Key="OneTimeBindingView_DescPart5">интерфейс.</system:String>
    <system:String x:Key="OneTimeBindingView_Example1_Title">📌 ПРИМЕР 1: OneTime привязка (не обновляется)</system:String>
    <system:String x:Key="OneTimeBindingView_Header_Editor">Редактируемые поля (TwoWay)</system:String>
    <system:String x:Key="OneTimeBindingView_Header_OneTimeFixed">OneTime привязка (не меняется)</system:String>
    <system:String x:Key="OneTimeBindingView_Section_ChangeDataInCode">🔄 Изменяем данные в коде</system:String>
    <system:String x:Key="OneTimeBindingView_SliderDemoTitle">🎚️ Слайдер меняет цену (TwoWay)</system:String>
    <system:String x:Key="OneTimeBindingView_PriceLabel">Цена:</system:String>
    <system:String x:Key="OneTimeBindingView_ExplanationTitle">📌 Что демонстрирует OneTime привязка:</system:String>
    <system:String x:Key="OneTimeBindingView_Bullet_LeftColumn">Левая колонка (TwoWay) - данные обновляются при любых изменениях</system:String>
    <system:String x:Key="OneTimeBindingView_Bullet_RightColumnFixed">Правая колонка (OneTime) - застыла при загрузке и не меняется</system:String>
    <system:String x:Key="OneTimeBindingView_Bullet_KeepRightColumnUnchanged">Нажимай кнопки, двигай слайдер - правая колонка остается неизменной</system:String>
    <system:String x:Key="OneTimeBindingView_Conclusion">OneTime привязка берет значение модели один раз при загрузке и больше не обновляется, даже если модель меняется</system:String>

    <system:String x:Key="Button_OneTime_SetLaptop">Установить "Ноутбук"</system:String>
    <system:String x:Key="Button_OneTime_SetPhone">Установить "Телефон"</system:String>
    <system:String x:Key="Button_SetPrice50000">Цена 50000</system:String>
    <system:String x:Key="Button_OneTime_ResetAll">Сбросить</system:String>

    <system:String x:Key="Label_NameOneTimeColon">Название (OneTime):</system:String>
    <system:String x:Key="Label_PriceOneTimeColon">Цена (OneTime):</system:String>
    <system:String x:Key="Label_QuantityOneTimeColon">Количество (OneTime):</system:String>
    <system:String x:Key="Label_TotalOneTimeColon">Итого (OneTime):</system:String>
    <system:String x:Key="Label_TotalColon">Итого:</system:String>

    <!-- OneWayBindingView -->
    <system:String x:Key="OneWayBindingView_Title">➡️ Односторонние привязки (OneWay)</system:String>
    <system:String x:Key="OneWayBindingView_DescPart1">OneWay привязка: данные текут</system:String>
    <system:String x:Key="OneWayBindingView_DescPart2">только из модели в интерфейс</system:String>
    <system:String x:Key="OneWayBindingView_DescPart3">. Пользователь может видеть данные, но не может их изменить через этот элемент.</system:String>
    <system:String x:Key="OneWayBindingView_Example1_Title">📌 ПРИМЕР 1: TextBlock с OneWay (только просмотр)</system:String>
    <system:String x:Key="OneWayBindingView_Header_EditTwoWay">Редактирование (TwoWay)</system:String>
    <system:String x:Key="OneWayBindingView_Header_ViewOneWay">Просмотр (OneWay)</system:String>
    <system:String x:Key="OneWayBindingView_Example2_Title">📊 ПРИМЕР 2: Визуальные элементы с OneWay</system:String>
    <system:String x:Key="Label_ProgressPrice">Прогресс цены:</system:String>
    <system:String x:Key="Label_LastUpdateTime">Последнее изменение:</system:String>
    <system:String x:Key="OneWayBindingView_Example3_Title">🎚️ ПРИМЕР 3: Слайдер (TwoWay) и индикаторы (OneWay)</system:String>
    <system:String x:Key="OneWayBindingView_ControlSliderLabel">Управляй ценой через слайдер:</system:String>
    <system:String x:Key="OneWayBindingView_CurrentPriceLabel">Текущая цена:</system:String>
    <system:String x:Key="OneWayBindingView_ProductNameLabel">Название товара:</system:String>
    <system:String x:Key="OneWayBindingView_Example4_Title">🔄 ПРИМЕР 4: OneWay vs OneTime (наглядное сравнение)</system:String>
    <system:String x:Key="OneWayBindingView_CompareGrid_Header_Editor">Редактор (TwoWay)</system:String>
    <system:String x:Key="OneWayBindingView_CompareGrid_Header_OneWay">OneWay (обновляется)</system:String>
    <system:String x:Key="OneWayBindingView_CompareGrid_Header_OneTime">OneTime (застыл)</system:String>
    <system:String x:Key="OneWayBindingView_TestButtonsTitle">🎮 Тестовые кнопки (меняют данные в модели)</system:String>
    <system:String x:Key="OneWayBindingView_ExplanationTitle">📌 Что демонстрирует OneWay привязка:</system:String>
    <system:String x:Key="OneWayBindingView_Bullet1">OneWay элементы показывают данные, но не могут их изменить</system:String>
    <system:String x:Key="OneWayBindingView_Bullet2">При изменении модели все OneWay элементы обновляются автоматически</system:String>
    <system:String x:Key="OneWayBindingView_Bullet3">Идеально для отображения информации, статистики, прогресса</system:String>
    <system:String x:Key="OneWayBindingView_Bullet4">В отличие от OneTime, OneWay продолжает следить за изменениями</system:String>

    <!-- TriggersView -->
    <system:String x:Key="TriggersView_Title">⚡ Триггеры в WPF</system:String>
    <system:String x:Key="TriggersView_Subtitle">Триггеры позволяют изменять внешний вид элементов при выполнении определенных условий</system:String>
    <system:String x:Key="TriggersView_PropertyTriggerTitle">🔹 1. PropertyTrigger (свойство элемента)</system:String>
    <system:String x:Key="TriggersView_PropertyTriggerExplanation">Срабатывает при изменении свойства самого элемента (IsMouseOver, IsFocused, IsChecked)</system:String>
    <system:String x:Key="TriggersView_Example1_Title">Кнопка с триггером на наведение</system:String>
    <system:String x:Key="Triggers_Button_HoverMouse">Наведи мышку</system:String>
    <system:String x:Key="TriggersView_Example1_Hint">✓ IsMouseOver: меняет цвет, размер, шрифт</system:String>
