    <system:String x:Key="TriggersView_Example2_Hint">Цвет фона меняется при отметке</system:String>
    <system:String x:Key="TriggersView_Example3_Title">TextBox с триггером на IsFocused</system:String>
    <system:String x:Key="TriggersView_Example3_Hint">✓ При фокусе: синяя рамка, голубой фон</system:String>

    <system:String x:Key="TriggersView_DataTriggerTitle">🔹 2. DataTrigger (привязка к данным)</system:String>
    <system:String x:Key="TriggersView_DataTriggerExplanation">Срабатывает при изменении данных в модели (привязка к свойству)</system:String>
    <system:String x:Key="Triggers_Table_Header_Product">Товар</system:String>
    <system:String x:Key="Triggers_Table_Header_Price">Цена</system:String>
    <system:String x:Key="Triggers_Table_Header_Quantity">Кол-во</system:String>
    <system:String x:Key="Triggers_Table_Header_Status">Статус</system:String>

    <system:String x:Key="TriggersView_Status_Normal">Обычный</system:String>
    <system:String x:Key="TriggersView_Status_Free">Бесплатно</system:String>
    <system:String x:Key="TriggersView_Status_NotAvailable">Нет в наличии</system:String>
    <system:String x:Key="TriggersView_Status_Premium">Премиум</system:String>

    <system:String x:Key="TriggersView_EventTriggerTitle">🔹 3. EventTrigger (события и анимация)</system:String>
    <system:String x:Key="TriggersView_EventTriggerExplanation">Срабатывает при возникновении события (Click, Loaded, MouseEnter) и запускает анимацию</system:String>
    <system:String x:Key="TriggersView_EventExample1_Title">Кнопка с анимацией при клике</system:String>
    <system:String x:Key="Triggers_Button_ClickMe">Нажми меня</system:String>
    <system:String x:Key="TriggersView_EventExample1_Hint">✓ При клике: мигает и сжимается</system:String>
    <system:String x:Key="TriggersView_EventExample2_Title">Анимация при наведении</system:String>
    <system:String x:Key="TriggersView_EventExample3_Title">Анимация при загрузке</system:String>
    <system:String x:Key="TriggersView_EventExample3_LargeTitle">⚡ Триггеры в действии ⚡</system:String>

    <system:String x:Key="TriggersView_MultiTriggerTitle">🔹 4. MultiTrigger и MultiDataTrigger (несколько условий)</system:String>
    <system:String x:Key="TriggersView_MultiTriggerExplanation">Срабатывают при выполнении нескольких условий одновременно</system:String>
    <system:String x:Key="Triggers_Discount_ConditionsLabel">Условия для скидки:</system:String>
    <system:String x:Key="Triggers_CheckBox_RegularCustomer">Постоянный клиент</system:String>
    <system:String x:Key="Triggers_CheckBox_HasPromoCode">Есть промокод</system:String>
    <system:String x:Key="Triggers_CheckBox_IsHoliday">Праздничный день</system:String>
    <system:String x:Key="Triggers_MyDiscountLabel">Ваша скидка:</system:String>

    <system:String x:Key="TriggersView_SummaryTitle">📊 Сводка по триггерам:</system:String>
    <system:String x:Key="TriggersView_Summary_PropertyTrigger">PropertyTrigger</system:String>
    <system:String x:Key="TriggersView_Summary_PropertyTriggerDescription">Реагирует на свойства элемента (IsMouseOver, IsFocused и др.)</system:String>
    <system:String x:Key="TriggersView_Summary_DataTrigger">DataTrigger</system:String>
    <system:String x:Key="TriggersView_Summary_DataTriggerDescription">Реагирует на изменения в данных (привязка к модели)</system:String>
    <system:String x:Key="TriggersView_Summary_EventTrigger">EventTrigger</system:String>
    <system:String x:Key="TriggersView_Summary_EventTriggerDescription">Запускает анимацию при событии (Click, Loaded и др.)</system:String>
    <system:String x:Key="TriggersView_Summary_MultiTrigger">MultiTrigger</system:String>
