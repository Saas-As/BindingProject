    <system:String x:Key="TriggersView_EventExample2_Title">Animation on hover</system:String>
    <system:String x:Key="TriggersView_EventExample3_Title">Animation on load</system:String>
    <system:String x:Key="TriggersView_EventExample3_LargeTitle">⚡ Triggers in action ⚡</system:String>

    <system:String x:Key="TriggersView_MultiTriggerTitle">🔹 4. MultiTrigger and MultiDataTrigger (multiple conditions)</system:String>
    <system:String x:Key="TriggersView_MultiTriggerExplanation">Triggers when multiple conditions are met simultaneously</system:String>
    <system:String x:Key="Triggers_Discount_ConditionsLabel">Discount conditions:</system:String>
    <system:String x:Key="Triggers_CheckBox_RegularCustomer">Regular customer</system:String>
    <system:String x:Key="Triggers_CheckBox_HasPromoCode">Has promo code</system:String>
    <system:String x:Key="Triggers_CheckBox_IsHoliday">Holiday</system:String>
    <system:String x:Key="Triggers_MyDiscountLabel">Your discount:</system:String>

