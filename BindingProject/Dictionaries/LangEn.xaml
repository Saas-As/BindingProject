                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Tab headers -->
    <system:String x:Key="Tab_DefaultBinding">Default Binding</system:String>
    <system:String x:Key="Tab_TwoWayBinding">TwoWay Binding</system:String>
    <system:String x:Key="Tab_OneTimeBinding">OneTime Binding</system:String>
    <system:String x:Key="Tab_OneWayBinding">OneWay Binding</system:String>
    <system:String x:Key="Tab_Triggers">Triggers</system:String>

    <!-- Window title -->
    <system:String x:Key="Language_Label">Language:</system:String>
    <system:String x:Key="MainWindow_Title">WPF Localization (Dictionary)</system:String>

    <!-- Common labels -->
    <system:String x:Key="Product_Name">Name</system:String>
    <system:String x:Key="Product_Price">Price</system:String>
    <system:String x:Key="Product_Quantity">Quantity</system:String>
    <system:String x:Key="Product_Total">Total</system:String>

    <!-- Buttons -->
    <system:String x:Key="Button_Reset">Reset</system:String>
    <system:String x:Key="Button_SetHighPrice">Set price 99999</system:String>
    <system:String x:Key="Button_SetLaptop">Laptop</system:String>
    <system:String x:Key="Button_SetPhone">Phone</system:String>
    <system:String x:Key="Button_SetPrice25000">Price 25000</system:String>
    <system:String x:Key="Button_SetPrice75000">Price 75000</system:String>

