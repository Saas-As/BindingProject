    <system:String x:Key="TriggersView_Summary_PropertyTrigger">PropertyTrigger</system:String>
    <system:String x:Key="TriggersView_Summary_PropertyTriggerDescription">Reacts to element properties (IsMouseOver, IsFocused, etc.)</system:String>
    <system:String x:Key="TriggersView_Summary_DataTrigger">DataTrigger</system:String>
    <system:String x:Key="TriggersView_Summary_DataTriggerDescription">Reacts to data changes (binding to model)</system:String>
    <system:String x:Key="TriggersView_Summary_EventTrigger">EventTrigger</system:String>
    <system:String x:Key="TriggersView_Summary_EventTriggerDescription">Starts animation on events (Click, Loaded, etc.)</system:String>
    <system:String x:Key="TriggersView_Summary_MultiTrigger">MultiTrigger</system:String>
    <system:String x:Key="TriggersView_Summary_MultiTriggerDescription">Triggers when multiple conditions are met</system:String>

    <!-- Product names -->
    <system:String x:Key="Product_Laptop">Laptop</system:String>
