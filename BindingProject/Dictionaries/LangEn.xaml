    <system:String x:Key="TriggersView_Status_NotAvailable">Out of stock</system:String>
    <system:String x:Key="TriggersView_Status_Premium">Premium</system:String>

    <system:String x:Key="TriggersView_EventTriggerTitle">🔹 3. EventTrigger (events and animation)</system:String>
    <system:String x:Key="TriggersView_EventTriggerExplanation">Triggers on event occurrence (Click, Loaded, MouseEnter) and starts animation</system:String>
    <system:String x:Key="TriggersView_EventExample1_Title">Button with click animation</system:String>
    <system:String x:Key="Triggers_Button_ClickMe">Click me</system:String>
