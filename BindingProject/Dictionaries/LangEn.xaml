    <!-- DefaultBindingView -->
    <system:String x:Key="DefaultBindingView_Title">🔹 Default Binding</system:String>
    <system:String x:Key="DefaultBindingView_Description">Default binding: WPF chooses the mode. For TextBox it's TwoWay (on LostFocus), for TextBlock it's OneWay.</system:String>
    <system:String x:Key="DefaultBindingView_EditableFieldsTitle">✏️ Editable fields (TextBox)</system:String>
    <system:String x:Key="DefaultBindingView_DisplayDataTitle">👁️ Data display (TextBlock)</system:String>
    <system:String x:Key="DefaultBindingView_UpdateSourceTriggerDemoTitle">⚡ UpdateSourceTrigger Demo</system:String>
    <system:String x:Key="DefaultBindingView_NormalTextBoxLabel">Normal TextBox (updates on LostFocus):</system:String>
    <system:String x:Key="DefaultBindingView_PropertyChangedTextBoxLabel">TextBox with PropertyChanged (updates on every keystroke):</system:String>
    <system:String x:Key="DefaultBindingView_DifferenceText">✏️ Difference: changes in the second field are immediately visible in the display block above</system:String>
    <system:String x:Key="DefaultBindingView_WhatDefaultShowsLabel">📌 What Default binding demonstrates:</system:String>
    <system:String x:Key="DefaultBindingView_Bullet1">When text changes in fields and focus is lost - display block updates</system:String>
    <system:String x:Key="DefaultBindingView_Bullet2">TOTAL updates automatically when price or quantity changes</system:String>
    <system:String x:Key="DefaultBindingView_Bullet3">UpdateSourceTrigger=PropertyChanged - updates after every character</system:String>
    <system:String x:Key="Button_DefaultBinding_ResetToDefault">↺ Reset to default values</system:String>

    <!-- TwoWayBindingView -->
    <system:String x:Key="TwoWayBindingView_Title">🔄 TwoWay Binding</system:String>
    <system:String x:Key="TwoWayBindingView_Description">TwoWay binding: changes in any field update all linked elements</system:String>
    <system:String x:Key="TwoWayBindingView_Example1_Title">📌 EXAMPLE 1: Two textboxes bound to one property</system:String>
    <system:String x:Key="TwoWayBindingView_Label_ProductNameEditAnyField">Product name (edit any field):</system:String>
    <system:String x:Key="TwoWayBindingView_UpHintText">⬆️ Change text in any field — the second updates immediately</system:String>
    <system:String x:Key="TwoWayBindingView_Example2_Title">📌 EXAMPLE 2: Slider and textbox for price</system:String>
    <system:String x:Key="TwoWayBindingView_PriceInstruction">Price (move slider or enter number):</system:String>
    <system:String x:Key="TwoWayBindingView_Example3_Title">📌 EXAMPLE 3: CheckBox controls visibility</system:String>
    <system:String x:Key="TwoWayBindingView_ShowExtraInfoLabel">Show additional information</system:String>
    <system:String x:Key="TwoWayBindingView_ExtraInfoText">This is additional info that appears/hides by checkbox</system:String>
    <system:String x:Key="TwoWayBindingView_Example4_Title">📌 EXAMPLE 4: Changing data in code</system:String>
    <system:String x:Key="TwoWayBindingView_ExplanationTitle">📌 What TwoWay binding demonstrates:</system:String>
    <system:String x:Key="TwoWayBindingView_ExplanationBullet1">• Changes in UI → update model</system:String>
    <system:String x:Key="TwoWayBindingView_ExplanationBullet2">• Changes in model (buttons) → update UI</system:String>
    <system:String x:Key="TwoWayBindingView_ExplanationBullet3">• All elements are synchronized with each other</system:String>
    <system:String x:Key="Button_TwoWay_ResetNameToNewProduct">Reset name to "New Product"</system:String>

    <!-- OneTimeBindingView -->
    <system:String x:Key="OneTimeBindingView_Title">⏱️ OneTime Binding</system:String>
    <system:String x:Key="OneTimeBindingView_DescPart1">OneTime binding updates the interface</system:String>
    <system:String x:Key="OneTimeBindingView_DescPart2">only once</system:String>
    <system:String x:Key="OneTimeBindingView_DescPart3">at load. Further data changes</system:String>
    <system:String x:Key="OneTimeBindingView_DescPart4">do not update</system:String>
    <system:String x:Key="OneTimeBindingView_DescPart5">the interface.</system:String>
    <system:String x:Key="OneTimeBindingView_Example1_Title">📌 EXAMPLE 1: OneTime binding (does not update)</system:String>
    <system:String x:Key="OneTimeBindingView_Header_Editor">Editable fields (TwoWay)</system:String>
    <system:String x:Key="OneTimeBindingView_Header_OneTimeFixed">OneTime binding (fixed)</system:String>
    <system:String x:Key="OneTimeBindingView_Section_ChangeDataInCode">🔄 Changing data in code</system:String>
    <system:String x:Key="OneTimeBindingView_SliderDemoTitle">🎚️ Slider changes price (TwoWay)</system:String>
    <system:String x:Key="OneTimeBindingView_PriceLabel">Price:</system:String>
    <system:String x:Key="OneTimeBindingView_ExplanationTitle">📌 What OneTime binding demonstrates:</system:String>
    <system:String x:Key="OneTimeBindingView_Bullet_LeftColumn">Left column (TwoWay) - data updates on any changes</system:String>
    <system:String x:Key="OneTimeBindingView_Bullet_RightColumnFixed">Right column (OneTime) - frozen at load and doesn't change</system:String>
    <system:String x:Key="OneTimeBindingView_Bullet_KeepRightColumnUnchanged">Click buttons, move slider - right column remains unchanged</system:String>
    <system:String x:Key="OneTimeBindingView_Conclusion">OneTime binding takes the model value once at load and never updates again, even if the model changes</system:String>

    <system:String x:Key="Button_OneTime_SetLaptop">Set "Laptop"</system:String>
    <system:String x:Key="Button_OneTime_SetPhone">Set "Phone"</system:String>
    <system:String x:Key="Button_SetPrice50000">Price 50000</system:String>
    <system:String x:Key="Button_OneTime_ResetAll">Reset</system:String>

    <system:String x:Key="Label_NameOneTimeColon">Name (OneTime):</system:String>
    <system:String x:Key="Label_PriceOneTimeColon">Price (OneTime):</system:String>
    <system:String x:Key="Label_QuantityOneTimeColon">Quantity (OneTime):</system:String>
    <system:String x:Key="Label_TotalOneTimeColon">Total (OneTime):</system:String>
    <system:String x:Key="Label_TotalColon">Total:</system:String>

    <!-- OneWayBindingView -->
    <system:String x:Key="OneWayBindingView_Title">➡️ OneWay Binding</system:String>
    <system:String x:Key="OneWayBindingView_DescPart1">OneWay binding: data flows</system:String>
    <system:String x:Key="OneWayBindingView_DescPart2">only from model to interface</system:String>
    <system:String x:Key="OneWayBindingView_DescPart3">. User can see data but cannot change it through this element.</system:String>
    <system:String x:Key="OneWayBindingView_Example1_Title">📌 EXAMPLE 1: TextBlock with OneWay (view only)</system:String>
    <system:String x:Key="OneWayBindingView_Header_EditTwoWay">Edit (TwoWay)</system:String>
    <system:String x:Key="OneWayBindingView_Header_ViewOneWay">View (OneWay)</system:String>
    <system:String x:Key="OneWayBindingView_Example2_Title">📊 EXAMPLE 2: Visual elements with OneWay</system:String>
    <system:String x:Key="Label_ProgressPrice">Price progress:</system:String>
    <system:String x:Key="Label_LastUpdateTime">Last update:</system:String>
    <system:String x:Key="OneWayBindingView_Example3_Title">🎚️ EXAMPLE 3: Slider (TwoWay) and indicators (OneWay)</system:String>
    <system:String x:Key="OneWayBindingView_ControlSliderLabel">Control price with slider:</system:String>
    <system:String x:Key="OneWayBindingView_CurrentPriceLabel">Current price:</system:String>
    <system:String x:Key="OneWayBindingView_ProductNameLabel">Product name:</system:String>
    <system:String x:Key="OneWayBindingView_Example4_Title">🔄 EXAMPLE 4: OneWay vs OneTime (visual comparison)</system:String>
    <system:String x:Key="OneWayBindingView_CompareGrid_Header_Editor">Editor (TwoWay)</system:String>
    <system:String x:Key="OneWayBindingView_CompareGrid_Header_OneWay">OneWay (updates)</system:String>
    <system:String x:Key="OneWayBindingView_CompareGrid_Header_OneTime">OneTime (frozen)</system:String>
    <system:String x:Key="OneWayBindingView_TestButtonsTitle">🎮 Test buttons (change data in model)</system:String>
    <system:String x:Key="OneWayBindingView_ExplanationTitle">📌 What OneWay binding demonstrates:</system:String>
    <system:String x:Key="OneWayBindingView_Bullet1">OneWay elements show data but cannot change it</system:String>
    <system:String x:Key="OneWayBindingView_Bullet2">When model changes, all OneWay elements update automatically</system:String>
    <system:String x:Key="OneWayBindingView_Bullet3">Ideal for displaying information, statistics, progress</system:String>
    <system:String x:Key="OneWayBindingView_Bullet4">Unlike OneTime, OneWay continues to track changes</system:String>

    <!-- TriggersView -->
    <system:String x:Key="TriggersView_Title">⚡ Triggers in WPF</system:String>
    <system:String x:Key="TriggersView_Subtitle">Triggers allow changing the appearance of elements when certain conditions are met</system:String>
    <system:String x:Key="TriggersView_PropertyTriggerTitle">🔹 1. PropertyTrigger (element property)</system:String>
    <system:String x:Key="TriggersView_PropertyTriggerExplanation">Triggers when an element's property changes (IsMouseOver, IsFocused, IsChecked)</system:String>
    <system:String x:Key="TriggersView_Example1_Title">Button with hover trigger</system:String>
    <system:String x:Key="Triggers_Button_HoverMouse">Hover mouse</system:String>
    <system:String x:Key="TriggersView_Example1_Hint">✓ IsMouseOver: changes color, size, font</system:String>
    <system:String x:Key="TriggersView_Example2_Title">CheckBox with IsChecked trigger</system:String>
    <system:String x:Key="Triggers_CheckBox_MarkMe">Check me</system:String>
    <system:String x:Key="TriggersView_Example2_Hint">Background color changes when checked</system:String>
    <system:String x:Key="TriggersView_Example3_Title">TextBox with focus trigger</system:String>
    <system:String x:Key="TriggersView_Example3_Hint">✓ On focus: blue border, light blue background</system:String>

    <system:String x:Key="TriggersView_DataTriggerTitle">🔹 2. DataTrigger (data binding)</system:String>
